PIXROMPT_USER_EMAIL=you@example.invalid
PIXROMPT_PASSWORD_HASH=<generate-with-server/scripts/hash_password.py>
PIXROMPT_TOKEN_SECRET=<random-32-byte-or-longer-secret>
PIXROMPT_DATABASE_PATH=/var/lib/pixrompt/pixrompt.sqlite3
PIXROMPT_BLOB_DIR=/var/lib/pixrompt/blobs
PIXROMPT_TOKEN_TTL_SECONDS=2592000
PIXROMPT_BASE_PATH=/v1
PIXROMPT_MAX_BLOB_BYTES=52428800
# Optional: set this to the Flutter web build directory to serve Pixrompt at /.
# Example after uploading a web build to the server:
# PIXROMPT_WEB_DIR=/var/www/pixrompt-web
PIXROMPT_WEB_DIR=
